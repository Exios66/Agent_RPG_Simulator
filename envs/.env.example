# Environment variables for Agent RPG Simulator (local development).
#
# Setup:
#   cp .env.example .env
#   # edit .env — never commit .env (see .gitignore)
#
# Hugging Face Inference API token (remote default backend).
# Create at: https://huggingface.co/settings/tokens
HF_TOKEN=

# OpenRouter API key (remote backend; OpenAI-compatible chat completions).
# Create at: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=
# Optional overrides (see agent_rpg.backends.openrouter.OpenRouterBackend):
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=https://github.com/your-org/your-repo
# OPENROUTER_APP_TITLE=Agent RPG Simulator

# Optional: run live Hugging Face pytest smoke test
# RUN_HF_LIVE=1
